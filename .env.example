# Copy this to .env and fill in real values

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Optional — defaults to local SQLite
# DATABASE_URL=sqlite:///data/keeper_league.db

# Set to "production" for secure cookies over HTTPS
# FLASK_ENV=production

# Set to 0 in production to disable debug mode
FLASK_DEBUG=1

# Server port (default 5000)
# PORT=5000

# Comma-separated origins for WebSocket CORS (default * for dev)
# ALLOWED_ORIGINS=https://yourdomain.com

# Optional — override data directory
# DATA_DIR=/var/lib/keeper-league/data
